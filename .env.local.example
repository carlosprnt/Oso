# Supabase — get these from your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Used only in server-side admin operations (optional for MVP)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App URL — used in Supabase OAuth redirects
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Gmail subscription detection ────────────────────────────────────────────
#
# NEXT_PUBLIC_GOOGLE_CLIENT_ID
#   Your Google OAuth 2.0 Client ID for the Gmail import feature.
#   How to get it:
#     1. Go to https://console.cloud.google.com/apis/credentials
#     2. Create an OAuth 2.0 Client ID (type: Web application)
#     3. Add your domain to "Authorized JavaScript Origins":
#          http://localhost:3000           (development)
#          https://your-domain.com        (production)
#     4. Enable the Gmail API in your project:
#          https://console.cloud.google.com/apis/library/gmail.googleapis.com
#
# GMAIL_MOCK=true
#   Skip real Gmail and return built-in sample data instead.
#   Automatically active in development when no token is present.
#
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GMAIL_MOCK=true
